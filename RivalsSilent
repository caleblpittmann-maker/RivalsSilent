local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local localPlayer = Players.LocalPlayer
local camera = workspace.CurrentCamera

local targetPlayer = nil
local autoEnabled = true
local isLeftMouseDown = false
local autoClickConnection

local AIM_FOV = 400 -- shooting radius (increase if you want it to lock further away)

-- UI
local gui = Instance.new("ScreenGui")
gui.ResetOnSpawn = false
gui.Parent = localPlayer:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0,170,0,80)
frame.Position = UDim2.new(0,20,0,200)
frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
frame.Parent = gui

local toggle = Instance.new("TextButton")
toggle.Size = UDim2.new(1,-10,0.5,-5)
toggle.Position = UDim2.new(0,5,0,5)
toggle.Text = "Auto Shoot: ON"
toggle.TextColor3 = Color3.new(1,1,1)
toggle.BackgroundColor3 = Color3.fromRGB(40,40,40)
toggle.Parent = frame

toggle.MouseButton1Click:Connect(function()
	autoEnabled = not autoEnabled
	toggle.Text = autoEnabled and "Auto Shoot: ON" or "Auto Shoot: OFF"
end)

-- lobby check
local function isLobbyVisible()
	return localPlayer.PlayerGui.MainGui.MainFrame.Lobby.Currency.Visible
end

-- ESP for bots / players
local function addESP(character)
	if character:FindFirstChild("BotESP") then return end

	local highlight = Instance.new("Highlight")
	highlight.Name = "BotESP"
	highlight.FillColor = Color3.fromRGB(0,255,0)
	highlight.FillTransparency = 0.35
	highlight.OutlineColor = Color3.fromRGB(255,255,255)
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent = character
end

for _,p in pairs(Players:GetPlayers()) do
	if p ~= localPlayer then
		if p.Character then
			addESP(p.Character)
		end
		p.CharacterAdded:Connect(addESP)
	end
end

-- closest player inside FOV
local function getClosestPlayerToMouse()
	local closest
	local shortest = AIM_FOV
	local mousePos = UserInputService:GetMouseLocation()

	for _,player in ipairs(Players:GetPlayers()) do
		if player ~= localPlayer and player.Character and player.Character:FindFirstChild("Head") then
			local head = player.Character.Head
			local pos, visible = camera:WorldToViewportPoint(head.Position)

			if visible then
				local screenPos = Vector2.new(pos.X,pos.Y)
				local dist = (screenPos - mousePos).Magnitude

				if dist < shortest then
					shortest = dist
					closest = player
				end
			end
		end
	end

	return closest
end

-- smooth aim
local function lockCameraToHead()
	if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("Head") then
		local head = targetPlayer.Character.Head
		local camPos = camera.CFrame.Position
		local targetCF = CFrame.new(camPos, head.Position)

		camera.CFrame = camera.CFrame:Lerp(targetCF, 0.25)
	end
end

-- autoclick
local function autoClick()
	if autoClickConnection then
		autoClickConnection:Disconnect()
	end

	autoClickConnection = RunService.Heartbeat:Connect(function()
		if isLeftMouseDown and autoEnabled and not isLobbyVisible() then
			mouse1click()
		end
	end)
end

-- input
UserInputService.InputBegan:Connect(function(input,processed)
	if processed then return end

	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		isLeftMouseDown = true
		autoClick()
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		isLeftMouseDown = false
	end
end)

-- aim loop (ONLY when shooting)
RunService.Heartbeat:Connect(function()
	if isLeftMouseDown and autoEnabled and not isLobbyVisible() then
		targetPlayer = getClosestPlayerToMouse()
		if targetPlayer then
			lockCameraToHead()
		end
	end
end)
